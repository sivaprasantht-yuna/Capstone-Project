# ─── JWT Configuration ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CapstoneHubSuperSecretKeyForJWTTokenGeneration2024!!!Change_This_In_Production

# ─── Cloudinary (File / PDF Storage) ─────────────────────────────────────────
# Sign up free at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ─── Database (override if not using docker-compose defaults) ────────────────
POSTGRES_DB=capstone_db
POSTGRES_USER=capstone_user
POSTGRES_PASSWORD=capstone_pass
